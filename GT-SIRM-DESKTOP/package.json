{
  "name": "gt-sirm",
  "version": "0.12.5",
  "description": "GnuTux Short Islamic Reels Maker — صانع ريلز إسلاميّة بجودة احترافيّة لـ GNU/Linux: قرآن، حديث، أذكار، أدعية، أسماء الله الحسنى، حِكَم",
  "author": "SalehGNUTUX <https://github.com/SalehGNUTUX>",
  "license": "GPL-3.0",
  "homepage": "https://github.com/SalehGNUTUX/GT-SIRM",
  "repository": {
    "type": "git",
    "url": "https://github.com/SalehGNUTUX/GT-SIRM.git"
  },
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "NODE_ENV=development electron .",
    "build": "bash ./scripts/build-all.sh appimage",
    "build:deb": "bash ./scripts/build-all.sh deb",
    "build:rpm": "bash ./scripts/build-all.sh rpm",
    "build:all": "bash ./scripts/build-all.sh all",
    "build:clean": "bash ./scripts/build-all.sh clean",
    "build:raw": "electron-builder --linux AppImage deb rpm",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "fluent-ffmpeg": "^2.1.3"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.9.0"
  },
  "build": {
    "appId": "org.gnutux.gt-sirm",
    "productName": "GT-SIRM",
    "copyright": "Copyright © 2026 SalehGNUTUX — GPLv3",
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "rpm"
      ],
      "synopsis": "GnuTux Short Islamic Reels Maker",
      "maintainer": "SalehGNUTUX <https://github.com/SalehGNUTUX>",
      "category": "AudioVideo",
      "icon": "GT-SIRM-icons/GT-SIRM-icon-original.png",
      "desktop": {
        "Name": "GT-SIRM",
        "Comment": "GnuTux Short Islamic Reels Maker",
        "Categories": "AudioVideo;Video;GTK;"
      },
      "extraFiles": [
        {
          "from": "resources/bin/",
          "to": "bin/",
          "filter": [
            "ffmpeg",
            "yt-dlp"
          ]
        }
      ]
    },
    "fileAssociations": [
      {
        "ext": "gtsirm",
        "name": "GT-SIRM Project",
        "description": "GT-SIRM Project File",
        "mimeType": "application/x-gtsirm-project",
        "role": "Editor"
      }
    ],
    "files": [
      "src/**/*",
      "GT-SIRM-icons/**/*",
      "!resources/bin/**/*"
    ],
    "directories": {
      "buildResources": "GT-SIRM-icons",
      "output": "dist"
    }
  }
}
